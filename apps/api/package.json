{
  "name": "@personal-crm/api",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "db:auth:generate": "pnpm exec better-auth generate --config ./src/lib/auth.ts --output ./src/db/schema/auth.generated.ts --yes",
    "db:generate": "pnpm exec drizzle-kit generate --config ./drizzle.config.ts",
    "db:migrate": "pnpm exec drizzle-kit migrate --config ./drizzle.config.ts",
    "db:studio": "pnpm exec drizzle-kit studio --config ./drizzle.config.ts",
    "lint": "pnpm exec ultracite check .",
    "start": "node dist/main.js",
    "test": "node -e \"console.log('TODO: add tests for @personal-crm/api')\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nestjs/common": "11.1.15",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.15",
    "@nestjs/platform-express": "11.1.15",
    "@nestjs/terminus": "11.1.1",
    "@thallesp/nestjs-better-auth": "2.4.0",
    "better-auth": "1.4.21",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.19.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@better-auth/cli": "1.4.21",
    "@nestjs/cli": "11.0.16",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "ts-node": "^10.9.2"
  }
}
